# --- Base de Datos (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=emi_user
DB_PASSWORD=emi_password
DB_NAME=emi_db

# --- Backend ---
BACKEND_PORT=3000
NODE_ENV=development

# --- pgAdmin ---
PGADMIN_EMAIL=admin@emi.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
